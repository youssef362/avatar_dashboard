# Re-pings unanswered @-mentions every 3 hours (free — runs on GitHub, not Vercel).
# Add two repo secrets: APP_URL (https://your-app.vercel.app) and CRON_SECRET (same as in Vercel).
name: Mention follow-ups
on:
  schedule:
    - cron: "0 */3 * * *"   # every 3 hours (UTC); GitHub may delay a few minutes
  workflow_dispatch: {}
jobs:
  ping:
    runs-on: ubuntu-latest
    steps:
      - name: Check unanswered mentions
        run: |
          curl -fsS -X GET "${{ secrets.APP_URL }}/api/mentions-check" \
            -H "Authorization: Bearer ${{ secrets.CRON_SECRET }}"
